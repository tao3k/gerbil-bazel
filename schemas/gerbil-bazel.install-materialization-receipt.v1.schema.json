{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tao3k/gerbil-bazel/schemas/gerbil-bazel.install-materialization-receipt.v1.schema.json",
  "title": "Gerbil Bazel Install Materialization Receipt v1",
  "type": "object",
  "required": [
    "schema",
    "outcome",
    "materialization",
    "installDigest",
    "prefix",
    "runner",
    "producerReceipt"
  ],
  "properties": {
    "schema": {"const": "gerbil-bazel.install-materialization-receipt.v1"},
    "outcome": {"const": "ready"},
    "materialization": {"enum": ["cache-hit", "built"]},
    "installDigest": {"$ref": "#/$defs/sha256"},
    "prefix": {"type": "string", "minLength": 1},
    "runner": {
      "type": "object",
      "required": [
        "name",
        "system",
        "architecture",
        "availableLogicalCpuCount"
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "system": {"enum": ["darwin", "linux"]},
        "architecture": {"enum": ["x86_64", "aarch64"]},
        "availableLogicalCpuCount": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "producerReceipt": {
      "type": "object",
      "required": ["path", "digestAlgorithm", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "digestAlgorithm": {"const": "sha256"},
        "digest": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
