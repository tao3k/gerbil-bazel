{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tao3k/gerbil-bazel/schemas/gerbil-bazel.project-request.v1.schema.json",
  "title": "Gerbil Bazel Project Request v1",
  "description": "Declared Bazel-to-Scheme request for one Gerbil project action.",
  "type": "object",
  "required": [
    "schema",
    "args",
    "buildScript",
    "dependencyRootMarker",
    "log",
    "packageIdentity",
    "packageRevision",
    "processGuard",
    "processGuardTimeoutSeconds",
    "projectDependencyRoots",
    "projectLabel",
    "projectRoot",
    "receipt",
    "receiptLinePrefix",
    "requireLibraryOutput",
    "sources",
    "tools"
  ],
  "properties": {
    "schema": {
      "const": "gerbil-bazel.project-request.v1"
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "buildScript": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "dependencyRootMarker": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "log": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "packageIdentity": {
      "type": "string"
    },
    "packageRevision": {
      "type": "string"
    },
    "processGuard": {
      "type": "boolean"
    },
    "processGuardTimeoutSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "projectDependencyRoots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "uniqueItems": true
    },
    "projectLabel": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "projectRoot": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "receipt": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "receiptLinePrefix": {
      "type": "string"
    },
    "requireLibraryOutput": {
      "type": "boolean"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "destination",
          "source"
        ],
        "properties": {
          "destination": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "source": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "additionalProperties": false
      }
    },
    "tools": {
      "type": "object",
      "required": [
        "as",
        "cc",
        "gxc",
        "gxi",
        "gxpkg",
        "ld"
      ],
      "properties": {
        "as": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cc": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gxc": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gxi": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gxpkg": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ld": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}
