    linux_prebuilt_urls = GERBIL_LINUX_URLS,
    project_dependency_source_packages = ["clan"],
    project_library_relative_path = "project-library",
    project_root_marker = "//tests/smoke:project-root.marker",
)
gerbil.source_package(
    name = "downloaded_fixture_sources",
    package = "gerbil-utils",
    sha256 = "e7777c505e71de490dc05f8e3ff4473dddbc998a99899c085d31750add551296",
