load(
    "@gerbil_bazel//gerbil:defs.bzl",
    "gerbil_project_compile",
    "gerbil_project_dev",
    "gerbil_project_test",
)

gerbil_project_compile(
    name = "compile",
    build_script = "build.ss",
    args = ["compile"],
)

gerbil_project_test(
    name = "test",
    build_script = "build.ss",
    srcs = ["smoke-test.ss"],
    tests = ["tests/smoke/smoke-test.ss"],
)

gerbil_project_dev(
    name = "dev",
    build_script = "build.ss",
    args = ["compile"],
)
