{
  "schema": "gerbil-bazel.source-build-config.v1",
  "contractVersion": 1,
  "outputIdentity": {
    "configureArguments": [
      "--enable-march="
    ],
    "upstreamEntrypoints": {
      "configure": "./configure",
      "buildStage": "./build.sh",
      "install": "make install"
    },
    "stageBuild": {
      "strategy": "upstream-exposed-stage-sequence",
      "sequence": [
        "prepare",
        "gambit",
        "boot-gxi",
        "stage0",
        "stage1",
        "stdlib",
        "libgerbil",
        "lang",
        "r7rs-large",
        "srfi",
        "tools"
      ],
      "checkpointBoundaries": [
        "stage1",
        "stdlib",
        "tools"
      ],
      "checkpointSchema": "gerbil-bazel.source-build-checkpoint.v1"
    }
  },
  "executionPolicy": {
    "buildTimeoutMinutes": 12,
    "terminationGraceSeconds": 30,
    "parallelism": {
      "source": "available-logical-cpus",
      "makeArgument": "-j"
    },
    "compilerCache": {
      "tool": "ccache",
      "maxSize": "2G"
    }
  }
}
